rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasValidGender() {
      return request.resource.data.gender in ['male', 'female'];
    }

    function hasValidScore() {
      return request.resource.data.bestScore is int
        && request.resource.data.bestScore >= 0
        && request.resource.data.bestScore <= 40;
    }

    function hasValidSundayChallengeScore() {
      return !('sundayChallengeBestScore' in request.resource.data)
        || (
          request.resource.data.sundayChallengeBestScore is int
          && request.resource.data.sundayChallengeBestScore >= 0
          && request.resource.data.sundayChallengeBestScore <= 18
        );
    }

    function hasNonDecreasingSundayChallengeScore() {
      return !('sundayChallengeBestScore' in resource.data)
        || (
          'sundayChallengeBestScore' in request.resource.data
          && request.resource.data.sundayChallengeBestScore >= resource.data.sundayChallengeBestScore
        );
    }

    function hasValidName() {
      return request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 1
        && request.resource.data.fullName.size() <= 80;
    }

    function hasValidPhoneNumber() {
      return request.resource.data.phoneNumber is string
        && request.resource.data.phoneNumber.size() >= 7
        && request.resource.data.phoneNumber.size() <= 20
        && request.resource.data.phoneNumber.matches('^[+0-9()\\-\\s]{7,20}$');
    }

    function hasValidAuthorName(fieldName, maxSize) {
      return request.resource.data[fieldName] is string
        && request.resource.data[fieldName].size() > 1
        && request.resource.data[fieldName].size() <= maxSize;
    }

    function hasValidText(fieldName, maxSize) {
      return request.resource.data[fieldName] is string
        && request.resource.data[fieldName].size() > 0
        && request.resource.data[fieldName].size() <= maxSize;
    }

    function hasValidOptionalText(fieldName, maxSize) {
      return !(fieldName in request.resource.data)
        || (
          request.resource.data[fieldName] is string
          && request.resource.data[fieldName].size() > 0
          && request.resource.data[fieldName].size() <= maxSize
        );
    }

    function hasValidOptionalAnnouncementVideoUrl() {
      return !('videoUrl' in request.resource.data)
        || (
          request.resource.data.videoUrl is string
          && request.resource.data.videoUrl.size() > 0
          && request.resource.data.videoUrl.size() <= 300
          && request.resource.data.videoUrl.matches('^https://.*$')
          && (
            request.resource.data.videoUrl.matches('^https://((www|m)\\.)?youtube\\.com/watch\\?v=[A-Za-z0-9_-]{11}$')
            || request.resource.data.videoUrl.matches('^https://((www|m)\\.)?youtube\\.com/embed/[A-Za-z0-9_-]{11}$')
            || request.resource.data.videoUrl.matches('^https://((www|m)\\.)?youtube\\.com/shorts/[A-Za-z0-9_-]{11}$')
            || request.resource.data.videoUrl.matches('^https://(www\\.)?youtu\\.be/[A-Za-z0-9_-]{11}$')
            || request.resource.data.videoUrl.matches('^https://(www\\.)?youtube-nocookie\\.com/embed/[A-Za-z0-9_-]{11}$')
          )
        );
    }

    function hasValidAnnouncementPosterData() {
      return request.resource.data.poster is map
        && request.resource.data.poster.keys().hasOnly(['name', 'type', 'size', 'url'])
        && request.resource.data.poster.name is string
        && request.resource.data.poster.name.size() > 0
        && request.resource.data.poster.name.size() <= 120
        && request.resource.data.poster.type is string
        && request.resource.data.poster.type.lower() in [
          'image/jpeg',
          'image/png',
          'image/webp',
          'image/gif',
          'image/heic',
          'image/heif'
        ]
        && request.resource.data.poster.size is int
        && request.resource.data.poster.size > 0
        && request.resource.data.poster.size <= 10485760
        && request.resource.data.poster.url is string
        && hasTrustedStorageUrl('poster');
    }

    function hasValidAnnouncementVideoData() {
      return request.resource.data.video is map
        && request.resource.data.video.keys().hasOnly(['name', 'type', 'size', 'url'])
        && request.resource.data.video.name is string
        && request.resource.data.video.name.size() > 0
        && request.resource.data.video.name.size() <= 120
        && request.resource.data.video.type is string
        && request.resource.data.video.type.lower() in [
          'video/mp4',
          'video/quicktime',
          'video/webm',
          'video/x-m4v'
        ]
        && request.resource.data.video.size is int
        && request.resource.data.video.size > 0
        && request.resource.data.video.size <= 20971520
        && request.resource.data.video.url is string
        && hasTrustedStorageUrl('video');
    }

    function hasValidOptionalAnnouncementPoster() {
      return !('poster' in request.resource.data)
        || hasValidAnnouncementPosterData();
    }

    function hasValidOptionalAnnouncementVideo() {
      return !('video' in request.resource.data)
        || hasValidAnnouncementVideoData();
    }

    function hasTrustedStorageUrl(fieldName) {
      return request.resource.data[fieldName].url.matches('^https://firebasestorage\\.googleapis\\.com/v0/b/bible-matrix(-[a-z0-9]+(-[a-z0-9]+)*)?\\.(firebasestorage\\.app|appspot\\.com)/o/.*$')
        || request.resource.data[fieldName].url.matches('^https://storage\\.googleapis\\.com/bible-matrix(-[a-z0-9]+(-[a-z0-9]+)*)?\\.(firebasestorage\\.app|appspot\\.com)/.*$');
    }

    function hasValidOptionalAttachment() {
      return !('attachment' in request.resource.data)
        || (
          request.resource.data.attachment is map
          && request.resource.data.attachment.keys().hasOnly(['name', 'type', 'size', 'url'])
          && request.resource.data.attachment.name is string
          && request.resource.data.attachment.name.size() > 0
          && request.resource.data.attachment.name.size() <= 120
          && request.resource.data.attachment.type is string
          && request.resource.data.attachment.type.lower() in [
            'application/pdf',
            'application/msword',
            'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
            'application/vnd.ms-excel',
            'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
            'image/jpeg',
            'image/png',
            'image/webp',
            'image/gif',
            'image/heic',
            'image/heif',
            'video/mp4',
            'video/quicktime',
            'video/webm',
            'video/x-m4v'
          ]
          && request.resource.data.attachment.size is int
          && request.resource.data.attachment.size > 0
          // 20 MB max file size.
          && request.resource.data.attachment.size <= 20971520
          && request.resource.data.attachment.url is string
          && hasTrustedStorageUrl('attachment')
        );
    }

    function hasValidGroupMessageContent() {
      return hasValidText('message', 400);
    }

    function hasValidOptionalStatusReply() {
      return !('statusReply' in request.resource.data)
        || (
          request.resource.data.statusReply is map
          && request.resource.data.statusReply.keys().hasOnly(['statusId', 'statusAuthorName', 'statusText', 'lukeReference'])
          && request.resource.data.statusReply.statusId is string
          && request.resource.data.statusReply.statusId.size() > 0
          && request.resource.data.statusReply.statusId.size() <= 120
          && request.resource.data.statusReply.statusAuthorName is string
          && request.resource.data.statusReply.statusAuthorName.size() > 0
          && request.resource.data.statusReply.statusAuthorName.size() <= 80
          && request.resource.data.statusReply.statusText is string
          && request.resource.data.statusReply.statusText.size() <= 180
          && (
            !('lukeReference' in request.resource.data.statusReply)
            || (
              request.resource.data.statusReply.lukeReference is string
              && request.resource.data.statusReply.lukeReference.size() <= 50
            )
          )
        );
    }

    function hasValidStatusReaction() {
      return request.resource.data.statusId is string
        && request.resource.data.statusId.size() > 0
        && request.resource.data.statusId.size() <= 120
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.emoji is string
        && request.resource.data.emoji in ['❤️', '🙏', '🔥', '👏', '😊']
        && request.resource.data.createdAt is timestamp;
    }

    function hasValidSundayServicePhotoData() {
      return request.resource.data.photo is map
        && request.resource.data.photo.keys().hasOnly(['name', 'type', 'size', 'url'])
        && request.resource.data.photo.name is string
        && request.resource.data.photo.name.size() > 0
        && request.resource.data.photo.name.size() <= 120
        && request.resource.data.photo.type is string
        && request.resource.data.photo.type.lower() in [
          'image/jpeg',
          'image/png',
          'image/webp',
          'image/gif',
          'image/heic',
          'image/heif'
        ]
        && request.resource.data.photo.size is int
        && request.resource.data.photo.size > 0
        && request.resource.data.photo.size <= 10485760
        && request.resource.data.photo.url is string
        && hasTrustedStorageUrl('photo');
    }

    function hasValidServiceDate() {
      return request.resource.data.serviceDate is string
        && request.resource.data.serviceDate.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && hasValidName()
        && hasValidGender()
        && hasValidPhoneNumber()
        && hasValidScore()
        && hasValidSundayChallengeScore();
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && hasValidName()
        && hasValidGender()
        && hasValidPhoneNumber()
        && hasValidScore()
        && hasValidSundayChallengeScore()
        && request.resource.data.bestScore >= resource.data.bestScore
        && hasNonDecreasingSundayChallengeScore();
      allow delete: if false;
    }

    match /lukeStatuses/{statusId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && hasValidAuthorName('authorName', 80)
        && hasValidText('text', 280)
        && hasValidOptionalText('lukeReference', 50)
        && hasValidOptionalAttachment()
        && request.resource.data.createdAt is timestamp;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /groupMessages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && hasValidAuthorName('authorName', 80)
        && hasValidGroupMessageContent()
        && hasValidOptionalStatusReply()
        && request.resource.data.createdAt is timestamp;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /statusReactions/{reactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && reactionId == request.auth.uid + '_' + request.resource.data.statusId
        && hasValidStatusReaction();
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && reactionId == request.auth.uid + '_' + request.resource.data.statusId
        && hasValidStatusReaction();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && hasValidAuthorName('authorName', 80)
        && hasValidText('title', 100)
        && hasValidOptionalText('message', 500)
        && hasValidOptionalAnnouncementVideoUrl()
        && hasValidOptionalAnnouncementPoster()
        && hasValidOptionalAnnouncementVideo()
        && (
          'message' in request.resource.data
          || 'videoUrl' in request.resource.data
          || 'poster' in request.resource.data
          || 'video' in request.resource.data
        )
        && request.resource.data.createdAt is timestamp;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /sundayServicePhotos/{photoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && hasValidAuthorName('authorName', 80)
        && hasValidServiceDate()
        && hasValidOptionalText('caption', 140)
        && hasValidSundayServicePhotoData()
        && request.resource.data.createdAt is timestamp;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
