rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasValidUploadSize(maxSizeBytes) {
      return request.resource != null
        && request.resource.size is int
        && request.resource.size > 0
        && request.resource.size <= maxSizeBytes;
    }

    function isAllowedStatusAttachmentType() {
      return request.resource != null
        && request.resource.contentType is string
        && request.resource.contentType.lower() in [
          'application/pdf',
          'application/msword',
          'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
          'application/vnd.ms-excel',
          'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
          'image/jpeg',
          'image/jpg',
          'image/png',
          'image/webp',
          'image/gif',
          'image/heic',
          'image/heif',
          'video/mp4',
          'video/quicktime',
          'video/webm',
          'video/x-m4v'
        ];
    }

    function isAllowedSundayPhotoType() {
      return request.resource != null
        && request.resource.contentType is string
        && request.resource.contentType.lower() in [
          'image/jpeg',
          'image/jpg',
          'image/png',
          'image/webp',
          'image/gif',
          'image/heic',
          'image/heif'
        ];
    }

    function isAllowedAnnouncementPosterType() {
      return request.resource != null
        && request.resource.contentType is string
        && request.resource.contentType.lower() in [
          'image/jpeg',
          'image/jpg',
          'image/png',
          'image/webp',
          'image/gif',
          'image/heic',
          'image/heif'
        ];
    }

    function isAllowedAnnouncementVideoType() {
      return request.resource != null
        && request.resource.contentType is string
        && request.resource.contentType.lower() in [
          'video/mp4',
          'video/quicktime',
          'video/webm',
          'video/x-m4v'
        ];
    }

    match /lukeStatuses/{userId}/{fileName=**} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && hasValidUploadSize(20971520)
        && isAllowedStatusAttachmentType();
      allow delete: if isOwner(userId);
    }

    match /sundayServicePhotos/{userId}/{fileName=**} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && hasValidUploadSize(10485760)
        && isAllowedSundayPhotoType();
      allow delete: if isOwner(userId);
    }

    match /announcements/{userId}/poster/{fileName=**} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && hasValidUploadSize(10485760)
        && isAllowedAnnouncementPosterType();
      allow delete: if isOwner(userId);
    }

    match /announcements/{userId}/video/{fileName=**} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && hasValidUploadSize(20971520)
        && isAllowedAnnouncementVideoType();
      allow delete: if isOwner(userId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
